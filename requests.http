# ============================================================
# Microservice Users  —  http://localhost:3002
# ============================================================

@usersBaseUrl = http://localhost:3002
@transactionsBaseUrl = http://localhost:3001

# Set this variable after running the Login request below
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJleHAiOjE3NzU2NDQ0MTYsImlhdCI6MTc3NTU1ODAxNiwic3ViIjoiZTdkNGEyOTEtMjE5MS00Mjk2LWIxODYtNTNkMDU2MGRlZWI2In0.wBHNZe-NK2W6FQ0YAHYDn2Lubohn5B1iIfdRcVLtVsI


### ── Auth ──────────────────────────────────────────────────

# Login
POST {{usersBaseUrl}}/auth
Content-Type: application/json

{
  "user": {
    "email": "jane.doe@example.com",
    "password": "secret123"
  }
}


### ── Users ─────────────────────────────────────────────────

# Create user
POST {{usersBaseUrl}}/users
Content-Type: application/json

{
  "first_name": "John",
  "last_name": "Doe",
  "email": "john.doe@example.com",
  "password": "secret123"
}


###

# List all users
GET {{usersBaseUrl}}/users
Authorization: Bearer {{token}}


###

# Get user by id
GET {{usersBaseUrl}}/users/e7d4a291-2191-4296-b186-53d0560deeb6
Authorization: Bearer {{token}}


###

# Update user by id
PATCH {{usersBaseUrl}}/users/e7d4a291-2191-4296-b186-53d0560deeb6
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "first_name": "Philippe",
  "last_name": "Berto",
  "email": "jane.doe@example.com",
  "password": "newpassword123"
}


###

# Delete user by id
DELETE {{usersBaseUrl}}/users/:id
Authorization: Bearer {{token}}


# ============================================================
# Microservice Wallet  —  http://localhost:3001
# ============================================================

### ── Transactions ──────────────────────────────────────────

# Create transaction
POST {{transactionsBaseUrl}}/transactions
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "ID": "00cf48cb-0ab1-4541-b740-8402f25a83ee",
  "type": "DEBIT",
  "amount": 100.67
}


###

# List all transactions (no filter)
GET {{transactionsBaseUrl}}/transactions
Authorization: Bearer {{token}}


###

# List transactions filtered by type
GET {{transactionsBaseUrl}}/transactions?type=debit
Authorization: Bearer {{token}}


###

# Get balance (consolidated CREDIT / DEBIT summary)
GET {{transactionsBaseUrl}}/balance
Authorization: Bearer {{token}}
